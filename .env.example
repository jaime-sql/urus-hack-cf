# Copy this file to `.env` and fill values. `.env` is ignored by Git.

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=

# Azure OpenAI (RAG)
AZURE_OPENAI_ENDPOINT=
# For AI Foundry project endpoint, use:
#   https://<instance>.services.ai.azure.com/api/projects/<project>/openai
# (Do NOT include /deployments/<name> here.)
# For classic Azure OpenAI resource, use:
#   https://<resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
# Optional explicit API version (defaults to a recent stable preview)
# For Foundry project endpoints, if unsure try 2024-10-21 first.
AZURE_OPENAI_API_VERSION=2024-10-21

# App settings (optional)
# LOG_LEVEL=INFO
